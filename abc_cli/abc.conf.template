# abc (AI Bash Command) configuration file
# See: https://getabc.sh/

[default]
provider = anthropic
# Anthropic API key from https://console.anthropic.com/settings/keys
api_key = {ANTHROPIC_API_KEY}
model = claude-sonnet-4-0

# Example configurations for other providers:

# [openai-gpt-5]  # OpenAI GPT-5 config
# provider = openai
# api_key = {OPENAI_API_KEY}  # OpenAI API key from https://platform.openai.com/api-keys
# model = gpt-5

# [bedrock-claude]  # AWS Bedrock Claude config
# provider = aws-bedrock
# profile = {AWS_PROFILE}  # ~/.aws/config profile name
# region = us-east-1  # AWS region
# model = anthropic.claude-sonnet-4-20250514-v1:0 # Bedrock inference profile

# [bedrock-nova-pro]  # AWS Bedrock Nova Pro config
# provider = aws-bedrock
# profile = {AWS_PROFILE}  # ~/.aws/config profile name
# region = us-east-1  # AWS region
# model = us.amazon.nova-pro-v1:0  # Bedrock inference profile

# Usage:
# - Default: abc "your command description"
# - Specific config: abc --use openai-gpt-5 "your command description"
